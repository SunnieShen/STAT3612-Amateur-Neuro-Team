        "        weight_decay=weight_decay,\n",
        "        patience=patience,\n",
        "        dropout=dropout,\n",
        "        device=device,\n",
        "        verbose=True,\n",
        "    )\n",
        "\n",
        "    print(f'\\n{\"=\"*60}')\n",
        "    print(f'  {name}')\n",
        "    print(f'{\"=\"*60}')\n",
