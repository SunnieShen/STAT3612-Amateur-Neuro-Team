        "            if sub.is_dir():\n",
        "                search_order.append(sub)\n",
        "\n",
        "    for start in search_order:\n",
        "        try:\n",
        "            start = start.resolve()\n",
        "        except OSError:\n",
        "            continue\n",
        "        for d in [start, *start.parents]:\n",
