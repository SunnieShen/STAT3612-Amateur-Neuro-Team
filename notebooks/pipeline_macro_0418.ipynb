        "    if d['y_proba'] is not None:\n",
        "        row['AUROC (macro)'] = roc_auc_score(y_val_bin, d['y_proba'],\n",
        "                                              average='macro', multi_class='ovr')\n",
        "    else:\n",
        "        row['AUROC (macro)'] = float('nan')\n",
        "    summary_rows.append(row)\n",
